{
  "name": "webbot-builder",
  "version": "1.0.17",
  "description": "Telegram-based chatbot orchestrator for automated website building and GitHub repo creation.",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "auth": "tsx src/whatsapp-auth.ts",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:fix": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "prepare": "husky",
    "setup": "tsx setup/index.ts",
    "reset:client": "tsx scripts/reset-client.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "docker:up": "bash scripts/docker-up.sh",
    "docker:build": "docker compose build && ./container/build.sh",
    "test:web": "bash scripts/test-web-agent.sh",
    "test:web:retrieval": "bash scripts/run-web-test.sh retrieval",
    "test:web:redesign": "bash scripts/run-web-test.sh redesign",
    "test:web:preview": "bash scripts/run-web-test.sh preview",
    "test:web:photo": "bash scripts/run-web-test.sh photo",
    "test:web:e2e": "bash scripts/run-web-test.sh e2e",
    "test:web:verbose": "bash scripts/run-web-test.sh e2e --verbose",
    "test:flow": "bash scripts/test-flow.sh",
    "test:flow:verbose": "bash scripts/test-flow.sh --verbose",
    "test:e2e": "tsx scripts/test-flow-e2e.ts",
    "test:e2e:verbose": "tsx scripts/test-flow-e2e.ts --verbose",
    "test:e2e:clean": "npm run reset:client -- client1 c:774133756 --hard && npm run docker:build && npm run test:e2e -- --verbose"
  },
  "dependencies": {
    "@google/genai": "^1.0.0",
    "@octokit/rest": "^22.0.1",
    "@types/ioredis": "^4.28.10",
    "axios": "^1.13.6",
    "better-sqlite3": "^11.8.1",
    "cron-parser": "^5.5.0",
    "dotenv": "^17.3.1",
    "google-it": "^1.6.4",
    "grammy": "^1.40.1",
    "inquirer": "^13.3.0",
    "ioredis": "^5.10.0",
    "node-fetch": "^3.3.2",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "yaml": "^2.8.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.0",
    "@types/qrcode-terminal": "^0.12.2",
    "@vitest/coverage-v8": "^4.0.18",
    "husky": "^9.1.7",
    "prettier": "^3.8.1",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=20"
  }
}
